.Dd June 11, 2026
.Dt LIBHMAC 3
.Os
.Sh NAME
.Nm libhmac.h
.Nd Library to support various Hash-based Message Authentication Codes (HMAC)
.Sh SYNOPSIS
.In libhmac.h
.Pp
Support functions
.nf
.Ft const char *
.Fo libhmac_get_version
.Fa "void"
.Fc
.fi
.Pp
Error functions
.nf
.Ft void
.Fo libhmac_error_free
.Fa "libhmac_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libhmac_error_fprint
.Fa "libhmac_error_t *error"
.Fa "FILE *stream"
.Fc
.fi
.nf
.Ft int
.Fo libhmac_error_sprint
.Fa "libhmac_error_t *error"
.Fa "char *string"
.Fa "size_t size"
.Fc
.fi
.nf
.Ft int
.Fo libhmac_error_backtrace_fprint
.Fa "libhmac_error_t *error"
.Fa "FILE *stream"
.Fc
.fi
.nf
.Ft int
.Fo libhmac_error_backtrace_sprint
.Fa "libhmac_error_t *error"
.Fa "char *string"
.Fa "size_t size"
.Fc
.fi
.Pp
MD5 context functions
.nf
.Ft int
.Fo libhmac_md5_context_initialize
.Fa "libhmac_md5_context_t **context"
.Fa "libhmac_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libhmac_md5_context_free
.Fa "libhmac_md5_context_t **context"
