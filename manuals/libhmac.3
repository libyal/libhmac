.Fc
.fi
.nf
.Ft int
.Fo libhmac_md5_context_update
.Fa "libhmac_md5_context_t *context"
.Fa "const uint8_t *buffer"
.Fa "size_t size"
.Fa "libhmac_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libhmac_md5_context_finalize
.Fa "libhmac_md5_context_t *context"
.Fa "uint8_t *hash"
.Fa "size_t hash_size"
.Fa "libhmac_error_t **error"
.Fc
.fi
.Pp
MD5 functions
.nf
.Ft int
.Fo libhmac_md5_calculate
.Fa "const uint8_t *buffer"
